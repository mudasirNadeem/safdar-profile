# Copy this file to .env and fill in real values. NEVER commit .env.
# In Vercel, set these same keys under Project Settings -> Environment Variables.

# Neon Postgres connection string (from the Neon console).
# IMPORTANT: rotate this if it was ever shared in plaintext.
DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require&channel_binding=require

# Secret used to sign admin login tokens. Use a long random string.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-string

# Admin account seeded by `npm run db:seed-admin`.
ADMIN_EMAIL=admin@gmail.com
ADMIN_PASSWORD=admin123
